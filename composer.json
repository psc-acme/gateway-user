{
    "name": "psc-acme/gateway-user",
    "description": "Package gateway-user for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\GatewayUser\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/event-dispatcher": "^7.0",
        "symfony/cache": "^7.0",
        "symfony/symfony": "^6.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}